{
  "name": "@crud1/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "frontend:build": "npx nx build frontend",
    "frontend:clean": "rimraf apps/frontend/.next",
    "frontend:dev": "npm run frontend:clean && npm run frontend:build && npx nx dev frontend",
    "backend:build": "npx nx build backend",
    "backend:clean": "rimraf apps/backend/dist",
    "backend:dev": "npm run backend:clean && npm run backend:build && npx nx serve backend",
    "apps:dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "frontend:production": "npm run frontend:clean && npm run frontend:build && npx nx start frontend",
    "backend:production": "npm run backend:clean && npm run backend:build && npx nx serve backend",
    "apps:production": "concurrently \"npm run frontend:production\" \"npm run backend:production\"",
    "lib:generate": "npx nx g @nx/js:lib",
    "lib:remove": "npx nx g @nx/workspace:remove"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "axios": "^1.6.0",
    "compression": "^1.8.1",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "express-useragent": "^2.2.0",
    "helmet": "^8.2.0",
    "joi": "^18.2.3",
    "mongoose": "^9.7.3",
    "nestjs-joi": "^1.12.0",
    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.0",
    "trim-request": "^1.0.6",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/nest": "23.0.1",
    "@nx/next": "^23.0.1",
    "@nx/node": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/webpack": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/compression": "^1.8.1",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "nx": "23.0.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1"
  },
  "workspaces": [
    "apps/*",
    "library",
    "shared"
  ]
}
